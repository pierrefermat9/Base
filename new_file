async function withdrawAll(){
  setSts('admin-sts','pnd','Kasalar kontrol ediliyor...');
  var list=[
    {c:new ethers.Contract(ADDR.CHECKIN,ABIS.CK,sgn),a:ADDR.CHECKIN,name:'Check-in'},
    {c:new ethers.Contract(ADDR.GM,ABIS.MSG,sgn),a:ADDR.GM,name:'GM'},
