<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap');
:root{
  --blue:#0052FF;--blue-dark:#003dbf;--blue-light:#e6eeff;
  --gold:#F59E0B;--purple:#7C3AED;
  --green:#10B981;--green-light:#D1FAE5;
  --red:#EF4444;--red-light:#FEE2E2;
  --warn:#F59E0B;--warn-light:#FEF9C3;
  --bg:#fff;--bg2:#f8f8f7;--bg3:#f0f0ee;
  --bdr:rgba(0,0,0,.10);--tx:#1a1a18;--tx2:#6b6b67;
  --r:12px;--rs:8px;--shadow:0 2px 8px rgba(0,82,255,.08);
}
@media(prefers-color-scheme:dark){
  :root{
    --bg:#141413;--bg2:#1e1e1b;--bg3:#252521;
    --bdr:rgba(255,255,255,.10);--tx:#f0efea;--tx2:#9c9a92;
    --blue-light:#0c1a3d;--green-light:#042f1e;
    --red-light:#2d0a0a;--warn-light:#2d1f00;
    --shadow:0 2px 8px rgba(0,0,0,.25);
  }
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-tap-highlight-color:transparent}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;min-height:100dvh}
.wrap{max-width:520px;margin:0 auto;padding:20px 16px 72px}
@supports(padding-bottom:env(safe-area-inset-bottom)){.wrap{padding-bottom:calc(72px + env(safe-area-inset-bottom))}}

.hdr{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:16px;border-bottom:.5px solid var(--bdr)}
.logo{width:42px;height:42px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 0 4px rgba(0,82,255,.12)}
.hdr-txt h1{font-family:'Space Mono',monospace;font-size:16px;font-weight:700}
.hdr-txt p{font-size:11px;color:var(--tx2);margin-top:2px}
.net-pill{margin-left:auto;display:flex;align-items:center;gap:5px;background:var(--blue-light);color:var(--blue);font-size:11px;font-weight:600;padding:5px 10px;border-radius:20px;border:.5px solid rgba(0,82,255,.25);white-space:nowrap}
.dot{width:6px;height:6px;border-radius:50%;background:var(--tx2);flex-shrink:0;animation:blink 2s infinite}
.dot.green{background:var(--green);box-shadow:0 0 0 2px rgba(16,185,129,.25);animation:none}
.dot.red{background:var(--red);animation:none}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}

.nwrn{background:var(--warn-light);border:.5px solid #fcd34d;border-radius:var(--rs);padding:11px 14px;font-size:13px;color:#92400E;margin-bottom:14px;align-items:center;gap:8px;display:none}
.nwrn.on{display:flex}
@media(prefers-color-scheme:dark){.nwrn,.nwrn.on{color:#fcd34d}}
.nwrn button{margin-left:auto;background:var(--warn);color:#fff;border:none;padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-weight:600}

.wlt-card{background:var(--bg2);border:.5px solid var(--bdr);border-radius:var(--r);padding:14px 16px;margin-bottom:16px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow)}
.wlt-info{flex:1;min-width:0}
.wlt-info .lbl{font-size:11px;color:var(--tx2);font-weight:500}
.wlt-info .adr{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.btn-con{background:var(--blue);color:#fff;border:none;padding:9px 16px;border-radius:var(--rs);font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .15s}
.btn-con:active{transform:scale(.97)}
.btn-con.off{background:var(--bg3);color:var(--tx2);border:.5px solid var(--bdr)}

.tabs{display:flex;gap:2px;background:var(--bg2);border:.5px solid var(--bdr);border-radius:10px;padding:4px;margin-bottom:20px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{flex:1;min-width:60px;padding:8px 6px;border:none;background:transparent;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;color:var(--tx2);white-space:nowrap;font-family:'DM Sans',sans-serif;transition:all .18s}
.tab.on{background:var(--bg);color:var(--tx);box-shadow:0 1px 4px rgba(0,0,0,.08);font-weight:600}
.tab-admin{display:none}
.tab-admin.show{display:block;color:var(--red);font-weight:700}

.pane{display:none}.pane.on{display:block}

.card{background:var(--bg);border:.5px solid var(--bdr);border-radius:var(--r);padding:20px;margin-bottom:16px;box-shadow:var(--shadow)}
.ctitle{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--tx2);margin-bottom:14px}
.irow{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:.5px solid var(--bdr);font-size:13px}
.irow:last-of-type{border-bottom:none}
.irow .il{color:var(--tx2)}
.irow .iv{font-weight:600;font-family:'Space Mono',monospace;font-size:12px}

.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.sc{background:var(--bg);border:.5px solid var(--bdr);border-radius:var(--r);padding:18px 16px;text-align:center;box-shadow:var(--shadow)}
.sn{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;line-height:1}
.sl{font-size:12px;color:var(--tx2);margin-top:6px;font-weight:500}

.abtn{width:100%;padding:14px;border:none;border-radius:10px;font-size:15px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-family:'DM Sans',sans-serif;transition:all .15s}
.abtn:active{transform:scale(.98)}
.abtn-dp{background:var(--blue);color:#fff}
.abtn-dp:hover:not(:disabled){background:var(--blue-dark)}
.abtn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}

.sts{margin-top:14px;padding:12px 14px;border-radius:var(--rs);font-size:13px;display:none;align-items:flex-start;gap:9px;word-break:break-word}
.sts.on{display:flex}
.sts.pnd{background:var(--warn-light);color:#92400E;border:.5px solid #fcd34d}
.sts.ok{background:var(--green-light);color:#065F46;border:.5px solid #6ee7b7}
.sts.err{background:var(--red-light);color:#7F1D1D;border:.5px solid #fca5a5}
@media(prefers-color-scheme:dark){.sts.pnd{color:#fcd34d}.sts.ok{color:#34d399}.sts.err{color:#fca5a5}}
.spin{width:14px;height:14px;border-radius:50%;border:2px solid currentColor;border-top-color:transparent;animation:spin_anim .65s linear infinite;flex-shrink:0}
@keyframes spin_anim{to{transform:rotate(360deg)}}

.fbox{display:flex;justify-content:space-between;align-items:center;border-radius:var(--rs);padding:10px 14px;margin-bottom:14px;font-size:13px}
.fbox-dp{background:var(--blue-light);border:.5px solid rgba(0,82,255,.25)}

.gm-gn-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.gm-card{background:var(--bg);border:.5px solid var(--bdr);border-radius:var(--r);padding:20px;box-shadow:var(--shadow)}
.gm-icon{font-size:40px;text-align:center;margin-bottom:12px}

/* GAMES SUB-TABS */
.sub-tabs{display:flex;gap:6px;margin-bottom:16px}
.sub-tab{flex:1;padding:10px 6px;border:1.5px solid var(--bdr);background:var(--bg2);border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;color:var(--tx2);font-family:'DM Sans',sans-serif;transition:all .18s;text-align:center}
.sub-tab.on{background:var(--blue);color:#fff;border-color:var(--blue)}

.sub-pane{display:none}.sub-pane.on{display:block}

/* DICE */
.dice-masa{background:linear-gradient(145deg,#1a7a42,#0d4a28);border-radius:16px;border:6px solid #8B6914;padding:32px 20px;margin-bottom:14px;display:flex;justify-content:center;gap:40px;min-height:150px;align-items:center}
.dice-box{width:80px;height:80px;background:#fff;border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:3px 4px 12px rgba(0,0,0,.5);transition:background .2s}
.dice-res{text-align:center;font-weight:700;font-size:18px;min-height:28px;margin-bottom:10px;font-family:'Space Mono',monospace}

/* WHEEL */
.wheel-wrapper{position:relative;display:inline-block;margin-bottom:15px}
.wheel-pointer{position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:24px;z-index:10}
#wheel-cv{border-radius:50%;box-shadow:0 4px 24px rgba(0,0,0,.2)}
.wheel-res{font-weight:700;font-size:18px;min-height:28px;margin-bottom:10px;font-family:'Space Mono',monospace;text-align:center}

/* PAC-MAN */
.pm-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.pm-stat{font-family:'Space Mono',monospace;font-size:13px;font-weight:700}
.pm-label{font-size:10px;color:var(--tx2);margin-bottom:2px}
#pm-canvas{display:block;margin:0 auto;border-radius:8px;border:2px solid var(--bdr);background:#000;max-width:100%}
.pm-dpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:14px;max-width:180px;margin-left:auto;margin-right:auto}
.pm-dpad button{padding:16px 0;border:none;border-radius:10px;background:var(--bg2);border:.5px solid var(--bdr);font-size:22px;cursor:pointer;transition:all .12s;-webkit-tap-highlight-color:transparent;user-select:none}
.pm-dpad button:active{background:var(--blue);color:#fff;transform:scale(.92)}
.pm-dpad .empty{background:transparent;border:none;pointer-events:none}
.pm-overlay{position:relative}
#pm-msg{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,.85);color:#fff;padding:16px 24px;border-radius:12px;text-align:center;font-family:'Space Mono',monospace;font-size:14px;line-height:1.6;display:none;z-index:10;white-space:nowrap}
#pm-msg.on{display:block}
.pm-lives{display:flex;gap:4px;align-items:center}

/* MODAL */
.mbg{position:fixed;inset:0;background:rgba(0,0,0,.65);display:flex;align-items:center;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .2s;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);padding:16px}
.mbg.on{opacity:1;pointer-events:all}
.mdl{background:var(--bg);border-radius:16px;padding:24px;width:100%;max-width:340px;max-height:80vh;overflow-y:auto;border:.5px solid var(--bdr);box-shadow:0 20px 60px rgba(0,0,0,.3)}
.mdl h2{margin-bottom:6px;font-size:18px;font-weight:700}
.mdl-sub{font-size:13px;color:var(--tx2);margin-bottom:18px}
.wopt{display:flex;align-items:center;gap:12px;padding:12px 14px;border:.5px solid var(--bdr);border-radius:10px;cursor:pointer;margin-bottom:8px;background:var(--bg2);transition:all .2s}
.wopt:hover{border-color:var(--blue);background:var(--blue-light)}
.wopt:active{transform:scale(.98)}
.wico{width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:8px;background:var(--bg3);flex-shrink:0;overflow:hidden}
.wico img{width:24px;height:24px;object-fit:contain}
.wico span{font-size:20px;line-height:1}
.wnm{font-weight:600;font-size:14px}
.wrdns{font-size:11px;color:var(--tx2);margin-top:2px}
.mdl-cls{width:100%;margin-top:12px;padding:12px;background:var(--bg2);border:.5px solid var(--bdr);border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;color:var(--tx2);font-family:'DM Sans',sans-serif;transition:all .15s}
.mdl-cls:hover{background:var(--bg3);color:var(--tx)}

.lvl-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;background:var(--blue-light);color:var(--blue)}

#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:#1a1a18;color:#fff;padding:10px 20px;border-radius:100px;font-size:13px;font-weight:500;z-index:99999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;max-width:90vw;overflow:hidden;text-overflow:ellipsis}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* XP WIDGET - sabit konum */
#xp-widget{
  position:fixed;top:12px;right:12px;z-index:1000;
  background:linear-gradient(135deg,#0052FF,#7C3AED);
  color:#fff;border-radius:20px;padding:6px 12px;
  font-family:'Space Mono',monospace;font-size:12px;font-weight:700;
  box-shadow:0 2px 12px rgba(0,82,255,.35);
  display:flex;align-items:center;gap:5px;
  transition:transform .2s;cursor:default;
  pointer-events:none;
}
#xp-widget.pop{transform:scale(1.18);}
#xp-widget-val{font-size:13px;}

/* SAYI OYUNU */
.numgame-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:18px}
.num-btn{
  padding:14px 0;border:2px solid var(--bdr);border-radius:10px;
  background:var(--bg2);font-size:18px;font-weight:700;
  cursor:pointer;transition:all .18s;font-family:'Space Mono',monospace;
  color:var(--tx);
}
.num-btn:active{transform:scale(.94)}
.num-btn.selected{background:var(--blue);color:#fff;border-color:var(--blue);transform:scale(1.07)}
.num-btn.win{background:#10B981;color:#fff;border-color:#10B981;}
.num-btn.lose{background:var(--bg3);color:var(--tx2);border-color:var(--bdr);}
.spin-circle{
  width:160px;height:160px;border-radius:50%;
  border:5px solid var(--blue);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 16px;
  background:linear-gradient(135deg,var(--blue-light),var(--bg));
  box-shadow:0 0 0 6px rgba(0,82,255,.12), inset 0 2px 12px rgba(0,82,255,.1);
  position:relative;overflow:hidden;
  transition:border-color .3s;
}
.spin-circle.spinning{animation:pulse-ring 0.4s ease infinite alternate;}
.spin-circle.win-glow{border-color:#10B981;box-shadow:0 0 0 8px rgba(16,185,129,.2),0 0 30px rgba(16,185,129,.4);}
.spin-circle.lose-glow{border-color:var(--red);box-shadow:0 0 0 8px rgba(239,68,68,.1);}
@keyframes pulse-ring{from{box-shadow:0 0 0 4px rgba(0,82,255,.2);}to{box-shadow:0 0 0 10px rgba(0,82,255,.1);}}
.spin-number{font-family:'Space Mono',monospace;font-size:64px;font-weight:700;line-height:1;color:var(--blue);}
.spin-number.win-num{color:#10B981;}
.spin-number.lose-num{color:var(--red);}
</style>
</head>
<body>
<div id="xp-widget">
  <span>&#9889;</span>
  <span id="xp-widget-val">0 XP</span>
</div>
<div class="wrap">

  <div class="hdr">
    <div class="logo">
      <svg viewBox="0 0 32 32" fill="none" width="24" height="24">
        <circle cx="16" cy="16" r="14" fill="#0052FF"/>
        <path d="M16 4C9.373 4 4 9.373 4 16s5.373 12 12 12c5.435 0 10.035-3.6 11.5-8.571H16v-2.857h12.857a12 12 0 000-1.143H16v-2.857h11.5C26.035 7.6 21.435 4 16 4z" fill="white"/>
      </svg>
    </div>
    <div class="hdr-txt">
      <h1>Base Fun dApp</h1>
      <p>Check-in &#8226; GM/GN &#8226; Games</p>
    </div>
    <div class="net-pill">
      <div class="dot" id="net-dot"></div>
      <span id="net-name">Bekleniyor</span>
    </div>
  </div>

  <div class="nwrn" id="net-warn">
    &#9888; Lutfen Base Mainnet'e gecin.
    <button onclick="switchToBase()">Agi Degistir</button>
  </div>

  <div class="wlt-card">
    <div class="wlt-info">
      <div class="lbl">Cuzdan</div>
      <div class="adr" id="wlt-adr">Bagli degil</div>
    </div>
    <button class="btn-con" id="con-btn" onclick="handleWalletAction()">Baglan</button>
  </div>

  <div class="tabs">
    <button class="tab on" id="tab-checkin" onclick="switchTab('checkin')">&#128197; Check-in</button>
    <button class="tab" id="tab-gm" onclick="switchTab('gm')">&#9728; GM/GN</button>
    <button class="tab" id="tab-games" onclick="switchTab('games')">&#127918; Games</button>
    <button class="tab tab-admin" id="tab-admin" onclick="switchTab('admin')">&#128273; Admin</button>
  </div>

  <!-- PANE: CHECK-IN -->
  <div class="pane on" id="pane-checkin">
    <div class="g2">
      <div class="sc"><div class="sn" style="color:var(--blue)" id="ck-streak">0</div><div class="sl">&#128293; Gunluk Seri</div></div>
      <div class="sc"><div class="sn" style="color:var(--green)" id="ck-total">0</div><div class="sl">&#9889; Toplam XP</div></div>
    </div>
    <div class="card">
      <div class="ctitle">Profil &amp; XP Bilgisi</div>
      <div class="irow"><span class="il">Seviye</span><span id="xp-level-global" class="iv lvl-badge">&#129355; Bronz</span></div>
      <div class="irow"><span class="il">Gunluk Sifirlanma</span><span class="iv">00:00 TR</span></div>
      <div class="irow" style="border-bottom:none"><span class="il">Durum</span><span id="ck-status" class="iv">Cuzdan bekleniyor</span></div>
      <div class="fbox fbox-dp" style="margin-top:14px">
        <span style="color:var(--tx2)">Ucret</span>
        <span style="font-weight:700;font-family:'Space Mono',monospace">0.00001 ETH</span>
      </div>
      <button class="abtn abtn-dp" id="ck-btn" onclick="doCheckIn()">&#128197; Check-in Yap</button>
      <div class="sts" id="ck-sts"></div>
    </div>
    <div class="card">
      <div class="ctitle">XP Seviye Rehberi</div>
      <div class="irow"><span class="il">&#129355; Bronz</span><span class="iv">0 – 999 XP</span></div>
      <div class="irow"><span class="il">&#129356; Gumus</span><span class="iv">1.000 – 4.999 XP</span></div>
      <div class="irow"><span class="il">&#129357; Altin</span><span class="iv">5.000 – 9.999 XP</span></div>
      <div class="irow"><span class="il">&#128142; Platin</span><span class="iv">10.000 – 49.999 XP</span></div>
      <div class="irow"><span class="il">&#128081; Elmas</span><span class="iv">50.000+ XP</span></div>
    </div>
  </div>

  <!-- PANE: GM/GN -->
  <div class="pane" id="pane-gm">
    <div class="fbox fbox-dp" style="margin-bottom:16px">
      <span style="color:var(--tx2)">Her mesaj ucreti</span>
      <span style="font-weight:700;font-family:'Space Mono',monospace">0.00001 ETH</span>
    </div>
    <div class="gm-gn-grid">
      <div class="gm-card">
        <div class="gm-icon">&#9728;</div>
        <div class="ctitle" style="text-align:center">GM Gonder</div>
        <button class="abtn" style="background:var(--gold);color:#fff;font-size:14px" onclick="sendMsg('gm')">&#9728; GM!</button>
        <div class="sts" id="gm-sts"></div>
      </div>
      <div class="gm-card">
