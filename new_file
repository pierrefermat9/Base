function drawWheel(angle){
  var cv=document.getElementById('wheel-cv'),ctx=cv.getContext('2d'),step=Math.PI*2/16;
  ctx.clearRect(0,0,280,280);
  for(var i=0;i<16;i++){
    ctx.beginPath();ctx.moveTo(140,140);ctx.arc(140,140,135,angle+i*step,angle+(i+1)*step);
    ctx.fillStyle=COLORS[i];ctx.fill();ctx.strokeStyle='rgba(255,255,255,.3)';ctx.lineWidth=1;ctx.stroke();
    ctx.save();ctx.translate(140,140);ctx.rotate(angle+i*step+step/2);
    ctx.fillStyle='#fff';ctx.font='bold 10px Space Mono';ctx.textAlign='center';
    ctx.fillText(SEGMENTS_XP[i]+' XP',88,4);ctx.restore();
  }
  ctx.beginPath();ctx.arc(140,140,18,0,Math.PI*2);
  ctx.fillStyle='#fff';ctx.fill();ctx.strokeStyle='rgba(0,0,0,.1)';ctx.lineWidth=2;ctx.stroke();
  ctx.fillStyle='#0052FF';ctx.font='bold 10px Space Mono';ctx.textAlign='center';ctx.fillText('BASE',140,144);
}
async function spinWheel(){
  if(!acct){openModal();return;}
  var btn=document.getElementById('spin-btn');btn.disabled=true;
  setSts('wheel-sts','pnd','Isleniyor...');
  try{
    var c=new ethers.Contract(ADDR.WHEEL,ABIS.WHEEL,sgn);
    var tx=await c.spin({value:ethers.parseEther('0.00005')});
    setSts('wheel-sts','pnd','Dogrulanıyor...');
    var receipt=await tx.wait();
    var iface=new ethers.Interface(ABIS.WHEEL);
    var wheelLog=receipt.logs.find(function(log){try{return iface.parseLog(log).name==="WheelSpun";}catch(e){return false;}});
    if(!wheelLog) throw new Error('Event bulunamadi');
    var parsed=iface.parseLog(wheelLog),winIdx=Number(parsed.args[1]);
    var step=Math.PI*2/16,targetA=-(winIdx*step+step/2)-Math.PI/2;
    var totalR=Math.PI*2*7+targetA-(wheelAngle%(Math.PI*2));
    var startA=wheelAngle,dur=4500,startT=performance.now();
    function anim(now){
      var prog=Math.min((now-startT)/dur,1);
      wheelAngle=startA+totalR*(1-Math.pow(1-prog,4));drawWheel(wheelAngle);
      if(prog<1){requestAnimationFrame(anim);}
      else{
        var xp=SEGMENTS_XP[winIdx];
        document.getElementById('wheel-res').textContent='+'+xp+' XP kazandin!';
        setSts('wheel-sts','ok','Tebrikler! +'+xp+' XP!');
        showToast('+'+xp+' XP!');btn.disabled=false;updateAllStats();
      }
    }
    requestAnimationFrame(anim);
  }catch(e){
    var msg=e.code===4001?'Islem reddedildi.':(e.reason||e.message||'').slice(0,80);
    setSts('wheel-sts','err','Hata: '+msg);btn.disabled=false;
  }
}

