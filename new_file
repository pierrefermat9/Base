    var trDayStart=nowTrTs-(nowTrTs%86400);
    var todayTrMidnightUtc=trDayStart+86400-TR_OFFSET;
    var lastResetUtc,nextResetUtc;
    if(nowTs>=todayTrMidnightUtc){lastResetUtc=todayTrMidnightUtc;nextResetUtc=todayTrMidnightUtc+86400;}
    else{lastResetUtc=todayTrMidnightUtc-86400;nextResetUtc=todayTrMidnightUtc;}
    var canCk=(lastTime===0)||(lastTime<lastResetUtc);
    var diffSec=nextResetUtc-nowTs;
    var statusTxt;
    if(canCk) statusTxt='Hazir!';
    else{var hh=Math.floor(diffSec/3600),mm=Math.floor((diffSec%3600)/60);statusTxt=hh+'s '+mm+'dk sonra (00:00 TR)';}
    document.getElementById('ck-status').textContent=statusTxt;
    document.getElementById('ck-btn').disabled=!canCk;
  }catch(e){}
}

