function ngInit() {
  var grid = document.getElementById('ng-grid');
  if (!grid || grid.children.length > 0) return;
  for (var i = 1; i <= 10; i++) {
    (function(num) {
      var btn = document.createElement('button');
      btn.className = 'num-btn';
      btn.id = 'ng-num-' + num;
      btn.textContent = num;
      btn.onclick = function() { ngSelect(num); };
      grid.appendChild(btn);
    })(i);
  }
}

function ngSelect(num) {
  if (NG.spinning) return;
  NG.selected = num;
  // Tüm butonları sıfırla
  for (var i = 1; i <= 10; i++) {
    var b = document.getElementById('ng-num-' + i);
    if (b) { b.className = 'num-btn' + (i === num ? ' selected' : ''); }
  }
  document.getElementById('ng-btn').disabled = false;
  document.getElementById('ng-result').textContent = num + ' sectiniz';
  document.getElementById('ng-result').style.color = 'var(--blue)';
  // Daire sıfırla
  var circle = document.getElementById('ng-circle');
  circle.className = 'spin-circle';
  var numEl = document.getElementById('ng-number');
  numEl.className = 'spin-number';
  numEl.textContent = '?';
}

async function ngSpin() {
  if (NG.selected === null || NG.spinning) return;
  if (!acct) { openModal(); return; }

  var chosen = NG.selected;
  var result = Math.floor(Math.random() * 10) + 1;

  NG.spinning = true;
  document.getElementById('ng-btn').disabled = true;
  document.getElementById('ng-sts').className = 'sts';
  document.getElementById('ng-result').textContent = '';

  var circle = document.getElementById('ng-circle');
  var numEl = document.getElementById('ng-number');

  // ADIM 1: Önce cüzdan onayını al
  setSts('ng-sts','pnd','Cuzdan onayi bekleniyor...');
  var tx;
  try {
    var c = new ethers.Contract(ADDR.NUMBER, ABIS.NUMBER, sgn);
    tx = await c.play(chosen, result, { value: ethers.parseEther('0.00001') });
  } catch(e) {
    NG.spinning = false;
    document.getElementById('ng-btn').disabled = false;
    var msg = e.code===4001 ? 'Islem reddedildi.' : (e.reason||e.message||'').slice(0,60);
    setSts('ng-sts','err','Hata: '+msg);
    return;
  }

  // ADIM 2: Onay alındı → animasyonu başlat
  setSts('ng-sts','pnd','Zincirde dogrulanıyor...');
  circle.className = 'spin-circle spinning';
  numEl.textContent = '?';

  var duration = 2200;
  var intervalMs = 80;
  var elapsed = 0;
  var displayNum = 1;

  // Animasyon ve TX onayını paralel çalıştır
  var txDone = false;
  var animDone = false;
  var receipt = null;

  // TX'i bekle (arka planda)
  tx.wait().then(function(r) {
    receipt = r;
    txDone = true;
    if (animDone) ngFinish(result, chosen);
  }).catch(function(e) {
    NG.spinning = false;
    document.getElementById('ng-btn').disabled = false;
    circle.className = 'spin-circle';
    setSts('ng-sts','err','TX hatasi: '+(e.reason||e.message||'').slice(0,60));
  });

  // Animasyon
  var ticker = setInterval(function() {
    elapsed += intervalMs;
    if (elapsed > duration * 0.7) intervalMs = 130;
    if (elapsed > duration * 0.85) intervalMs = 200;
    displayNum = (displayNum % 10) + 1;
    numEl.textContent = displayNum;
    if (elapsed >= duration) {
      clearInterval(ticker);
      numEl.textContent = result;
      circle.className = 'spin-circle';
      animDone = true;
      if (txDone) ngFinish(result, chosen);
    }
  }, intervalMs);
}

function ngFinish(result, chosen) {
  ngShowResult(result, chosen);
}

function ngShowResult(result, selected) {
  if (selected === undefined) selected = NG.selected;
  var isWin = result === selected;
  var xp = isWin ? 100 : selected;

  NG.localXP += xp;
  NG.spinning = false;

  var circle = document.getElementById('ng-circle');
  var numEl = document.getElementById('ng-number');
  var resultEl = document.getElementById('ng-result');

  if (isWin) {
    circle.className = 'spin-circle win-glow';
    numEl.className = 'spin-number win-num';
    resultEl.textContent = 'SUPER! +100 XP kazandin!';
    resultEl.style.color = '#10B981';
    showToast('SUPER! +100 XP!');
    // Kazanan butonu yeşile boya
    var wb = document.getElementById('ng-num-' + result);
    if (wb) wb.className = 'num-btn win selected';
  } else {
    circle.className = 'spin-circle lose-glow';
    numEl.className = 'spin-number lose-num';
    resultEl.textContent = selected + ' sectin, ' + result + ' geldi. +' + xp + ' XP!';
    resultEl.style.color = 'var(--tx)';
    showToast('+' + xp + ' XP kazandin!');
    // Doğru sayıyı göster
    for (var i = 1; i <= 10; i++) {
      var b = document.getElementById('ng-num-' + i);
      if (!b) continue;
      if (i === result) b.className = 'num-btn win';
      else if (i === selected) b.className = 'num-btn lose';
      else b.className = 'num-btn';
    }
  }

  setSts('ng-sts', 'ok', 'Bu turda +' + xp + ' XP! Toplam bu oyundan: ' + NG.localXP + ' XP');

  // XP widget - önce localXP'yi artır, sonra widget'ı güncelle
  updateXPWidget(xp); // animasyonlu artış

  // Tekrar oynamak için butonu aktif et (1 sn sonra)
  setTimeout(function() {
    document.getElementById('ng-btn').disabled = false;
    document.getElementById('ng-btn').textContent = 'Tekrar Cevir';
  }, 1000);
}

// ─── UI HELPERS ───────────────────────────────────────────────────────────────
function switchTab(n){
  document.querySelectorAll('.tab,.pane').forEach(function(el){el.classList.remove('on');});
  document.getElementById('tab-'+n).classList.add('on');
  document.getElementById('pane-'+n).classList.add('on');
  if(n==='games'){drawWheel(wheelAngle); drawDice('d1-svg','d1-box',1); drawDice('d2-svg','d2-box',1);}
}

function switchSubTab(n){
  document.querySelectorAll('.sub-tab,.sub-pane').forEach(function(el){el.classList.remove('on');});
  document.getElementById('stab-'+n).classList.add('on');
  document.getElementById('spane-'+n).classList.add('on');
  if(n==='wheel') drawWheel(wheelAngle);
  if(n==='dice'){drawDice('d1-svg','d1-box',1);drawDice('d2-svg','d2-box',1);}
  if(n==='pacman'&&!PM.started){pmDraw(1);}
  if(n==='numgame'){ngInit();}
}

function openModal(){document.getElementById('modal-bg').classList.add('on');}
function closeModal(){document.getElementById('modal-bg').classList.remove('on');}
function handleModalBgClick(e){if(e.target===document.getElementById('modal-bg'))closeModal();}

function updateXPWidget(addedXP) {
  // addedXP: sadece animasyon için kullanılır
  // Gerçek toplam: tüm kaynaklardan
  var wv = document.getElementById('xp-widget-val');
  var widget = document.getElementById('xp-widget');
  if (!wv || !widget) return;
  var current = parseInt(wv.textContent.replace(/[^0-9]/g,'')) || 0;
  var target = current + (addedXP || 0);
  var start = current, duration = 800, startT = performance.now();
  function anim(now) {
    var prog = Math.min((now - startT) / duration, 1);
    var ease = 1 - Math.pow(1 - prog, 3);
    var val = Math.round(start + (target - start) * ease);
    wv.textContent = val.toLocaleString('tr-TR') + ' XP';
    if (prog < 1) requestAnimationFrame(anim);
    else { wv.textContent = target.toLocaleString('tr-TR') + ' XP'; }
  }
  requestAnimationFrame(anim);
  widget.classList.add('pop');
  setTimeout(function() { widget.classList.remove('pop'); }, 400);
}

function setXPWidget(totalXP) {
  // Animasyonsuz — tüm kaynakların toplamını direkt yazar
  var wv = document.getElementById('xp-widget-val');
  var widget = document.getElementById('xp-widget');
  if (!wv || !widget) return;
  wv.textContent = totalXP.toLocaleString('tr-TR') + ' XP';
}

function setSts(id,type,html){
  var el=document.getElementById(id);
  el.className='sts on '+type;
  el.innerHTML=(type==='pnd'?'<div class="spin"></div>':'')+'<span>'+html+'</span>';
}
function getLevel(xp){
  if(xp>=50000) return '&#128081; Elmas';
  if(xp>=10000) return '&#128142; Platin';
  if(xp>=5000)  return '&#129357; Altin';
  if(xp>=1000)  return '&#129356; Gumus';
  return '&#129355; Bronz';
}

