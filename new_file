    {c:new ethers.Contract(ADDR.NUMBER,ABIS.NUMBER,sgn),a:ADDR.NUMBER,name:'NumberGame'}
  ];
  var success=[],failed=[],skipped=[];
  for(var i=0;i<list.length;i++){
